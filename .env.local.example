# ============================================================================
#  Variables de entorno — Porra Mundial 2026
#  Copia este archivo a ".env.local" y rellena los valores reales.
#  NUNCA subas ".env.local" a git (ya está en .gitignore).
# ============================================================================

# --- Supabase (panel del proyecto → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Clave service_role: SOLO se usa en el servidor (cron, admin, scripts).
# NO la pongas en variables NEXT_PUBLIC_. Es secreta.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# --- football-data.org (regístrate gratis y copia tu token) ---
# https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=tu-token-de-football-data

# --- Seguridad del cron ---
# Inventa una cadena larga y aleatoria. Vercel la envía en el header
# "Authorization: Bearer <CRON_SECRET>" al disparar el cron.
CRON_SECRET=cadena-larga-aleatoria-cambiame
